# Local AI proxy settings.
# Use this as a reference for shell exports or your hosting provider's secret/env UI.
# Vite can read .env files for extension builds, but npm run ai:server does not auto-load this file.

OPENAI_API_KEY=sk-proj-your-openai-api-key
OPENAI_MODEL=gpt-5.4-nano
PORT=8787

# Local development default is 127.0.0.1.
# Hosted deployments should use 0.0.0.0.
HOST=127.0.0.1

# Comma-separated exact origins. For production, set this to your extension origin:
# chrome-extension://your-extension-id
# If omitted, local dev allows chrome-extension://* plus localhost Vite origins.
ALLOWED_ORIGINS=

# Optional private-beta gate. This is not real user auth if bundled into the extension.
UI_REMIX_PROXY_TOKEN=

# Extension build-time settings.
VITE_AI_ENDPOINT=http://127.0.0.1:8787/api/interpret-command
VITE_UI_REMIX_PROXY_TOKEN=

# Proxy safety limits.
OPENAI_TIMEOUT_MS=15000
MAX_REQUEST_BYTES=180000
MAX_CANDIDATES=120
MAX_COMMAND_LENGTH=500
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30
