{
  "manifest_version": 3,
  "name": "UI Remix",
  "description": "Customize website UI with simple local rules.",
  "version": "0.1.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "UI Remix"
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["activeTab", "storage", "tabs", "scripting"],
  "host_permissions": ["<all_urls>"]
}
